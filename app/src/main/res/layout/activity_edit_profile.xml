<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8F9FA"
    android:orientation="vertical">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#153B75"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="16dp">

        <ImageView
            android:id="@+id/btnBackProfile"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@android:drawable/ic_menu_revert"
            app:tint="#FFFFFF" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginEnd="24dp"
            android:layout_weight="1"
            android:gravity="center"
            android:text="THÔNG TIN CÁ NHÂN"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:textStyle="bold" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Số điện thoại (Tài khoản đăng nhập)"
            android:textColor="#555555"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/edtSdtProfile"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="16dp"
            android:background="#E0E0E0"
            android:enabled="false"
            android:paddingHorizontal="16dp"
            android:textColor="#888888" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Họ và tên"
            android:textColor="#555555"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/edtHoTenProfile"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="16dp"
            android:background="@android:drawable/edit_text"
            android:hint="Nhập họ và tên của bạn"
            android:paddingHorizontal="16dp"
            android:textColor="#333333" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Email nhận thông báo"
            android:textColor="#555555"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/edtEmailProfile"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="24dp"
            android:background="@android:drawable/edit_text"
            android:hint="Ví dụ: datdo@gmail.com"
            android:inputType="textEmailAddress"
            android:paddingHorizontal="16dp"
            android:textColor="#333333" />
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Mật khẩu mới (Để trống nếu không đổi)"
            android:textColor="#555555"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/edtPassProfile"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="24dp"
            android:background="@android:drawable/edit_text"
            android:hint="Nhập mật khẩu mới"
            android:inputType="textPassword"
            android:paddingHorizontal="16dp"
            android:textColor="#333333" />
        <Button
            android:id="@+id/btnLuuProfile"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:backgroundTint="#153B75"
            android:text="LƯU THAY ĐỔI"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:textStyle="bold" />

    </LinearLayout>
</LinearLayout>