<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="16dp"
    android:layout_marginVertical="8dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="4dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <TextView
                android:id="@+id/tvNgayGioItem"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="24/06/2026 - 14:30"
                android:textColor="#333333"
                android:textSize="16sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvTrangThaiItem"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:background="@drawable/bg_status_pending"
                android:paddingHorizontal="12dp"
                android:paddingVertical="4dp"
                android:text="Đang chờ"
                android:textColor="#722ED1"
                android:textSize="12sp"
                android:textStyle="bold" />
        </RelativeLayout>

        <TextView
            android:id="@+id/tvMaLichItem"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Mã lịch: LH123456"
            android:textColor="#666666" />

        <TextView
            android:id="@+id/tvChiNhanhItem"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="🏠 Chi nhánh: 30Shine - Nguyễn Trãi"
            android:textColor="#555555"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/tvThoCatItem"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="✂️ Stylist: Đỗ Tiến Đạt"
            android:textColor="#555555"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/tvDichVuItem"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="💈 Dịch vụ: Cắt gội combo 2"
            android:textColor="#555555"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/tvTongTienItem"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Tổng thanh toán: 150.000 VNĐ"
            android:textColor="#2ECC71"
            android:textStyle="bold"
            android:visibility="gone" />

        <Button
            android:id="@+id/btnHuyLichItem"
            android:layout_width="match_parent"
            android:layout_height="40dp"
            android:layout_marginTop="12dp"
            android:backgroundTint="#F44336"
            android:text="HỦY LỊCH NÀY"
            android:textColor="#FFFFFF"
            android:visibility="gone" />

    </LinearLayout>
</androidx.cardview.widget.CardView>